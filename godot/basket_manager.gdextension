[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.2
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://../rust/target/debug/libbasket_ball_engine.so"
linux.release.x86_64 =   "res://../rust/target/release/libbasket_ball_engine.so"
windows.debug.x86_64 =   "res://../rust/target/debug/basket_ball_engine.dll"
windows.release.x86_64 = "res://../rust/target/release/basket_ball_engine.dll"
macos.debug =            "res://../rust/target/debug/libbasket_ball_engine.dylib"
macos.release =          "res://../rust/target/release/libbasket_ball_engine.dylib"
macos.debug.arm64 =      "res://../rust/target/debug/libbasket_ball_engine.dylib"
macos.release.arm64 =    "res://../rust/target/release/libbasket_ball_engine.dylib"
